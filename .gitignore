# Public-repo whitelist:
# ignore everything by default, then explicitly include the files and folders
# that are safe and useful to publish.
/*

!.gitignore
!README.md
!docs/
!docs/**
!games/
!games/shogun2/
!games/shogun2/README.md
!games/shogun2/build_x86.bat
!games/shogun2/dinput8_proxy.def
!games/shogun2/shogun2_mod.ini
!games/shogun2/src/
!games/shogun2/src/**
!games/shogun2/notes/
!games/shogun2/notes/**
!games/shogun2/tools/
!games/shogun2/tools/**
!games/shogun2/releases/
!games/shogun2/releases/**

/games/shogun2/build/
